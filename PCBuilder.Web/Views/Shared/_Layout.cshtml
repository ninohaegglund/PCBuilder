<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PCBuilder.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.css" />
    <link rel="stylesheet" href="~/PCBuilder.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body class="bg-primary-subtle">

    <header class="py-3">
        <nav class="navbar navbar-expand-lg playful-navbar">
            <div class="container">
                <a class="navbar-brand playful-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-pc-display-horizontal me-2"></i>
                    PCBuilder
                </a>

                <button class="navbar-toggler playful-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between" id="mainNavbar">
                    <ul class="navbar-nav gap-2 mx-auto my-3 my-lg-0">
                        <li class="nav-item">
                            <a class="nav-link playful-nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link playful-nav-link" asp-controller="Computer" asp-action="ComputerIndex">
                                <i class="bi bi-pc-display me-1"></i>Computers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link playful-nav-link" asp-controller="Computer" asp-action="CreateComputerIndex">
                                <i class="bi bi-wrench-adjustable-circle me-1"></i>Custom Build
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link playful-nav-link" asp-controller="Order" asp-action="OrderIndex">
                                <i class="bi bi-ticket-perforated-fill me-1"></i>Orders
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle playful-nav-link" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false">
                                <i class="bi bi-grid-3x3-gap-fill me-1"></i>More
                            </a>
                            <div class="dropdown-menu playful-dropdown">
                                <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                                <a class="dropdown-item" href="#">About</a>
                                <a class="dropdown-item" href="#">Workshop</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" href="#">Finances</a>
                            </div>
                        </li>
                    </ul>

                    <div class="navbar-actions d-flex align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <button class="btn playful-user-trigger dropdown-toggle"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">
                                    <i class="bi bi-person-circle me-2"></i>
                                    <span class="playful-user-name">@User.Identity.Name</span>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end playful-user-dropdown">
                                    <li>
                                        <div class="playful-user-dropdown-header">
                                            <div class="fw-bold">
                                                <i class="bi bi-person-badge me-2"></i>@User.Identity.Name
                                            </div>
                                            <small class="text-muted">Signed in</small>
                                        </div>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    <li>
                                        <a class="dropdown-item playful-user-dropdown-item"
                                           asp-controller="Home"
                                           asp-action="Index">
                                            <i class="bi bi-house-door-fill me-2"></i>Home
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item playful-user-dropdown-item"
                                           asp-controller="Computer"
                                           asp-action="ComputerIndex">
                                            <i class="bi bi-pc-display me-2"></i>Computers
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item playful-user-dropdown-item"
                                           asp-controller="Order"
                                           asp-action="OrderIndex">
                                            <i class="bi bi-bag-check-fill me-2"></i>Orders
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item playful-user-dropdown-item"
                                           asp-controller="Order"
                                           asp-action="OrderIndex">
                                            <i class="bi bi-nvidia me-2"></i>Components
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    <li class="px-2 pb-2">
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn playful-user-logout w-100">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <a asp-controller="Account" asp-action="Login" class="nav-link playful-nav-link">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                                <a asp-controller="Account" asp-action="Register" class="nav-link playful-nav-link">
                                    <i class="bi bi-person-plus-fill me-1"></i>Register
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
            <partial name="_Notifications" />
        </main>
    </div>

    <footer class="playful-footer mt-5">
        <div class="container py-4">
            <div class="row g-4 align-items-center">
                <div class="col-md-5">
                    <div class="footer-card">
                        <h5 class="mb-2 fw-bold">
                            <i class="bi bi-pc-display-horizontal me-2"></i>PCBuilder
                        </h5>
                        <p class="mb-0">
                            Build custom PCs, browse components, and explore playful ideas for your next machine.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="footer-card">
                        <h6 class="fw-bold mb-3">Quick Links</h6>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-controller="Home" asp-action="Index" class="footer-chip">Home</a>
                            <a asp-controller="Home" asp-action="Privacy" class="footer-chip">Privacy</a>
                            <a asp-controller="Computer" asp-action="ComputerIndex" class="footer-chip">Computers</a>
                            <a asp-controller="Order" asp-action="OrderIndex" class="footer-chip">Orders</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="footer-card text-md-end">
                        <div class="mb-2">
                            <a href="#" class="footer-icon"><i class="bi bi-github"></i></a>
                            <a href="#" class="footer-icon"><i class="bi bi-discord"></i></a>
                            <a href="#" class="footer-icon"><i class="bi bi-instagram"></i></a>
                        </div>
                        <small class="d-block">
                            <i class="bi bi-heart-fill me-1"></i>© 2025 PCBuilder.Web
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>