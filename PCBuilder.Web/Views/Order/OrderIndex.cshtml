@using PCBuilder.Services.CustomerAPI.DTO
@model IEnumerable<OrderListDTO>

<div class="card shadow border-0 mt-4">
    <div class="card-header border-dark-subtle bg-light bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-black">Order List</h1>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <table class="table table-borderless align-middle">
            <thead>
                <tr class="table-dark">
                    <th>Customer</th>
                    <th>Budget</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@item.CustomerImageUrl"
                                     alt="@item.CustomerName"
                                     style="width:50px; height:50px; object-fit:cover; border-radius:50%;" />
                                <span>@item.CustomerName</span>
                            </div>
                        </td>
                        <td>@item.Budget kr</td>
                        <td>@item.Description</td>
                        <td>@item.Status</td>
                        <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (item.Status == OrderStatus.Pending)
                            {
                                <a asp-route="AcceptOrderWeb" asp-route-orderId="@item.Id" class="btn btn-success btn-sm">
                                    <i class="bi bi-check-circle"></i> Accept
                                </a>
                            }
                            else if (item.Status == OrderStatus.InProgress)
                            {
                                <div class="d-flex gap-2">
                                    <a asp-controller="Computer" asp-action="CreateComputerIndex" asp-route-orderId="@item.Id" class="btn btn-info btn-sm">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <a asp-action="CompleteOrder" asp-route-orderId="@item.Id" class="btn btn-primary btn-sm">
                                        <i class="bi bi-check2-square"></i> Complete
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">No actions</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>