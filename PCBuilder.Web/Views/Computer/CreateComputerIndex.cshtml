@model PCBuilder.Service.BuilderServiceAPI.DTO.Response.ComputerCreateDTO

@{
    ViewData["Title"] = "Build Computer";
}

<form asp-action="Create" method="post">
    <div class="container mt-4 mb-5">
        <div class="builder-shell">

            <div class="builder-header text-center">
                <span class="builder-badge">Custom PC Builder</span>
                <h1 class="mb-2">Build Computer</h1>
                <p class="mb-0 text-muted">
                    Choose parts, peripherals, and accessories for your custom setup.
                </p>
            </div>

            <div class="builder-body">

                @if (ViewBag.AcceptedOrderId != null)
                {
                    <div class="alert alert-info border-0 shadow-sm" role="alert">
                        <div class="d-flex align-items-center gap-3">
                            @if (ViewBag.AcceptedOrderCustomerImageUrl != null)
                            {
                                <img src="@ViewBag.AcceptedOrderCustomerImageUrl"
                                     alt="@ViewBag.AcceptedOrderCustomerName"
                                     style="width:48px; height:48px; object-fit:cover; border-radius:50%;" />
                            }
                            <div>
                                <div class="fw-bold">Accepted order: #@ViewBag.AcceptedOrderId</div>
                                @if (ViewBag.AcceptedOrderCustomerName != null)
                                {
                                    <div class="small text-muted">Customer: @ViewBag.AcceptedOrderCustomerName</div>
                                }
                            </div>
                        </div>
                        <div>@ViewBag.AcceptedOrderDescription</div>
                    </div>
                }
                else if (ViewBag.OrderInfoError != null)
                {
                    <div class="alert alert-warning border-0 shadow-sm" role="alert">
                        @ViewBag.OrderInfoError
                    </div>
                }

                <div class="builder-section">
                    <h4 class="builder-section-title">
                        <i class="bi bi-tag-fill me-2"></i>Basic Info
                    </h4>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Name</label>
                        <input asp-for="Name" class="form-control playful-input" placeholder="Enter build name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="builder-section">
                    <h4 class="builder-section-title">
                        <i class="bi bi-pc-display-horizontal me-2"></i>Core Components
                    </h4>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CPUId" class="form-label fw-bold">CPU <i class="bi bi-cpu"></i></label>
                            <select asp-for="CPUId" asp-items="ViewBag.CPUs" class="form-select playful-input"></select>
                            <span asp-validation-for="CPUId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="MotherboardId" class="form-label fw-bold">Motherboard <i class="bi bi-motherboard"></i></label>
                            <select asp-for="MotherboardId" asp-items="ViewBag.Motherboards" class="form-select playful-input"></select>
                            <span asp-validation-for="MotherboardId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PSUId" class="form-label fw-bold">PSU <i class="bi bi-battery-charging"></i></label>
                            <select asp-for="PSUId" asp-items="ViewBag.PSUs" class="form-select playful-input"></select>
                            <span asp-validation-for="PSUId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CaseId" class="form-label fw-bold">Case <i class="bi bi-pc"></i></label>
                            <select asp-for="CaseId" asp-items="ViewBag.Cases" class="form-select playful-input"></select>
                            <span asp-validation-for="CaseId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CpuCoolerId" class="form-label fw-bold">Cooler <i class="bi bi-fan"></i></label>
                            <select asp-for="CpuCoolerId" asp-items="ViewBag.CPUCoolers" class="form-select playful-input"></select>
                            <span asp-validation-for="CpuCoolerId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="GPUIds" class="form-label fw-bold">GPU <i class="bi bi-nvidia"></i></label>
                            <select asp-for="GPUIds" asp-items="ViewBag.GPUs" class="form-select playful-input" multiple size="4"></select>
                            <span class="form-hint">Hold Ctrl / Cmd to select multiple GPUs.</span>
                            <span asp-validation-for="GPUIds" class="text-danger d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="RAMIds" class="form-label fw-bold">RAM <i class="bi bi-memory"></i></label>
                            <select asp-for="RAMIds" asp-items="ViewBag.RAMs" class="form-select playful-input" multiple size="4"></select>
                            <span class="form-hint">Select one or more RAM kits.</span>
                            <span asp-validation-for="RAMIds" class="text-danger d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StorageIds" class="form-label fw-bold">Storage <i class="bi bi-device-ssd"></i></label>
                            <select asp-for="StorageIds" asp-items="ViewBag.Storages" class="form-select playful-input" multiple size="4"></select>
                            <span class="form-hint">Select one or more drives.</span>
                            <span asp-validation-for="StorageIds" class="text-danger d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CaseFanIds" class="form-label fw-bold">Case Fans <i class="bi bi-fan"></i></label>
                            <select asp-for="CaseFanIds" asp-items="ViewBag.CaseFans" class="form-select playful-input" multiple size="4"></select>
                            <span class="form-hint">Select one or more case fans.</span>
                            <span asp-validation-for="CaseFanIds" class="text-danger d-block"></span>
                        </div>
                    </div>
                </div>

                <div class="builder-section">
                    <h4 class="builder-section-title">
                        <i class="bi bi-controller me-2"></i>Peripherals
                    </h4>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="KeyboardId" class="form-label fw-bold">Keyboard <i class="bi bi-keyboard"></i></label>
                            <select asp-for="KeyboardId" asp-items="ViewBag.Keyboards" class="form-select playful-input"></select>
                            <span asp-validation-for="KeyboardId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="MouseId" class="form-label fw-bold">Mouse <i class="bi bi-mouse"></i></label>
                            <select asp-for="MouseId" asp-items="ViewBag.Mice" class="form-select playful-input"></select>
                            <span asp-validation-for="MouseId" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="HeadsetId" class="form-label fw-bold">Headset <i class="bi bi-headset"></i></label>
                            <select asp-for="HeadsetId" asp-items="ViewBag.Headsets" class="form-select playful-input"></select>
                            <span asp-validation-for="HeadsetId" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="MonitorIds" class="form-label fw-bold">Monitor <i class="bi bi-display"></i></label>
                            <select asp-for="MonitorIds" asp-items="ViewBag.Monitors" class="form-select playful-input" multiple size="4"></select>
                            <span asp-validation-for="MonitorIds" class="text-danger d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SpeakerIds" class="form-label fw-bold">Speakers <i class="bi bi-speaker"></i></label>
                            <select asp-for="SpeakerIds" asp-items="ViewBag.Speakers" class="form-select playful-input" multiple size="4"></select>
                            <span asp-validation-for="SpeakerIds" class="text-danger d-block"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="builder-footer d-flex flex-column flex-md-row justify-content-between gap-3">

                <a asp-action="ComputerIndex" class="btn btn-outline-info">
                    <i class="bi bi-arrow-left"></i> View Computers
                </a>
                <button asp-action="CreateComputerIndex" type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg"></i> Create
                </button>
            </div>
        </div>
    </div>
</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}